# Betfair credentials
BETFAIR_APP_KEY=zzUJ33kRRSa1JPLO
BETFAIR_USERNAME=psychoffuk
BETFAIR_PASSWORD=b&B3122356589

# Paths to SSL cert files (non-interactive bot login)
BETFAIR_CERT_PATH=./certs/client-2048.crt
BETFAIR_KEY_PATH=./certs/client-2048.key

# geniusBackend base URL (running locally or on VPS)
GENIUS_BACKEND_URL=http://localhost:3003

# Genius Soccer sport ID (check /api/fixtures/sports to find it)
GENIUS_SOCCER_SPORT_ID=10

# Engine port
PORT=4001

# Polling interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=30000

# Booking coverage filter (set to 'false' to disable)
BOOKING_COVERAGE_ENABLED=true

# Supabase (same project as geniusBackend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scalpy (set SCALPY_DRY_RUN=false only when ready for live trading)
SCALPY_DRY_RUN=true
SCALPY_FEED_POLL_MS=3000

# Live settlement poll interval in ms (only active when SCALPY_DRY_RUN=false)
SCALPY_LIVE_SETTLE_MS=60000

# Safety brakes (Scalpy v2 Phase 1)
# Required to place real bets when SCALPY_DRY_RUN=false (two-flag arm; else startup force-kills):
SCALPY_LIVE_CONFIRM=
# Shared secret for the admin panel's mutating routes (required in live mode):
SCALPY_ADMIN_TOKEN=
# Refuse to bet on a feed that hasn't delivered an event within this many ms:
SCALPY_STALE_MS=45000

# Bind host (0.0.0.0 = reachable on the machine's real IP). Set 127.0.0.1 to restrict to local.
HOST=0.0.0.0
